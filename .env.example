# ═══════════════════════════════════════════════════
# Carnation Spa — Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git
# ═══════════════════════════════════════════════════

# ── Supabase ────────────────────────────────────────
# Get from: supabase.com → Project → Settings → Database
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:5432/postgres"

# Get from: supabase.com → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://[project-ref].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# Storage bucket name (create in Supabase dashboard)
SUPABASE_STORAGE_BUCKET="carnation-spa-media"

# ── Auth ─────────────────────────────────────────────
# Generate a strong random string (min 32 chars)
# Run: openssl rand -base64 32
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"

# ── Initial Owner Account ────────────────────────────
# Used during first database seed (npx prisma db seed)
ADMIN_PHONE="+19783300895"
ADMIN_PASSWORD="changeme123"
ADMIN_NAME="Admin"

# ── Twilio ────────────────────────────────────────────
# Get from: twilio.com → Console Dashboard
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your_auth_token"
TWILIO_PHONE_NUMBER="+1xxxxxxxxxx"
# Get from: twilio.com → Verify → Services
TWILIO_VERIFY_SERVICE_SID="VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ── App ──────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# In production: "https://carnation-spa.vercel.app"

# ── Cloudflare Turnstile (SMS anti-abuse) ────────────
# Get free keys from: dash.cloudflare.com → Turnstile → Add Site
# Widget type: Invisible
NEXT_PUBLIC_TURNSTILE_SITE_KEY="0x4AAAAAAA..."
TURNSTILE_SECRET_KEY="0x4AAAAAAA..."

# ── Android SMS Gateway（业务短信：预约确认/修改/提醒）──
# 验证码仍走 Twilio Verify，不受此影响
SMS_GATEWAY_URL="http://192.168.0.111:8080"
SMS_GATEWAY_USER="sms"
SMS_GATEWAY_PASS="your_gateway_password"

# ── Cron Security ────────────────────────────────────
# Vercel Cron calls this header to authenticate
# Generate: openssl rand -hex 32
CRON_SECRET="your-cron-secret-key"
